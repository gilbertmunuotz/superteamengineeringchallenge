{
  "expo": {
    "name": "tunzaapp",
    "slug": "tunzaapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app-icon.png",
    "scheme": "tunzaapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "icon": {
        "light": "./assets/app-icon.png"
      },
      "android": {
        "adaptiveIcon": {
          "foregroundImage": "./assets/adaptive-icon.png",
          "backgroundColor": "#ffffff"
        },
        "edgeToEdgeEnabled": true
      },
      "web": {
        "bundler": "metro",
        "output": "static",
        "favicon": "./assets/favicon.png"
      },
      "plugins": [
        "expo-router",
        [
          "expo-splash-screen",
          {
            "image": "./assets/splash-icon-dark.png",
            "imageWidth": 200,
            "resizeMode": "contain",
            "backgroundColor": "#ffffff"
          }
        ],
        "expo-router",
        [
          "expo-splash-screen",
          {
            "image": "./assets/splash-icon-dark.png",
            "imageWidth": 200,
            "resizeMode": "contain",
            "backgroundColor": "#ffffff"
          }
        ]
      ],
      "experiments": {
        "typedRoutes": true
      },
      "bundleIdentifier": "com.gilbertmunuotz.tunzaapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "extra": {
      "eas": {
        "projectId": "f431c5d9-d98a-4e56-b76c-cf8ad34f52aa"
      }
    },
    "owner": "gilbertmunuotz",
    "android": {
      "package": "com.gilbertmunuotz.tunzaapp"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser"
    ]
  }
}
